Table roles{
  	id integer [primary key]
  	role_name varchar(100)
}

Table users{
  	id integer [primary key]
  	email varchar(100)
  	password varchar (255)
  	role_id integer
  	is_active bollean
}
Table level{
	id integer [primary key]
	class integer
	grade varchar(1)
	level_name varchar(50)
}

Table employees{
 	id integer [primary key]
 	user_id integer 
 	employee_number varchar(255)
 	company varchar(255)
 	branch varchar(100)
 	branch_code integer
 	department varchar(255)
 	level_id integer
 	status_employee enum(contract, intership, permanent)
 	join_date date
 	contract_end_date date
 	approval_path varchar(50)
 	manager_employee_id integer
 
}


Table employee_profile{
	id integer [primary key]
	employe_id integer 
	first_name varchar(255)
	last_name varchar(255)
	phone_number varchar(50)
	additional_phone_number varchar(50)
	place_of_birth varchar(255)
	date_of_birth date
	gender enum (male, female)
	martial_status enum()
	blood_type varchar(20)
	religion Enum
	nik varhcar(20)
	no_paspor varchar(50)
	passport_expiration_date date
	postal_code integer
	address_according_to_id_card text
	domicile_address text
	
}

Table employee_emergency_contact{
	id integer [primary key]
	employee_id integer
	full_name varchar(255)
	relationship Enum
	phone_number varchar(15)
	email varchar(15)
	address text
}

Table employee_family_members{
	id integer [primary key]
	employee_id integer
	nik varchar(16)
	full_name varchar(255)
	relationship enum
	gender enum
	martial_status enum
	occupation varchar(100)
	created_at timestamp
	updated_at timestamp
}

Table employee_education{
	id integer [primary key]
	employee_id integer
	education_level enum
	institution_name varchar(255)
	major varchar(100)
	level varchar(50)
	start_year date
	end_year date
	gpa float
	type Enum(formal, informal)
	description text
	certificate text
	created_at timestamp
	updated_at timestamp
}




Table employee_work_experiences{
	id integer [primary key]
	employee_id integer
	company_name varchar(255)
	position varchar(255)
	start_date date
	end_date date
	job_description text
	created_at date
	updated_at date
}

Table employee_task_information{
	id integer [primary key]
	employee_id integer
	tax_number varchar(50)
	tax_status varchar(50)
	tax_method varchar(50)
	created_at timestamp
	updated_at timestamp
}

Table employee_insurances{
	id integer [primary key]
	employee_id integer
	insurance_type enum(BPJS_Kesehatan, BPJS_Ketenagakerjaan)
	insurance_number varchar(50)
	start_date date
	end_date date
	created_at timestamp
	updated_at timestamp
}

Table employee_bank_account{
	id integer [primary key]
	employee_id integer
	bank_name varchar(50)
	account_number varchar(50)
	account_holder_name varchar(255)
	is_primary bool
	created_at timestamp
	updated_at timestamp
}




